{
  "name": "stakezone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run client\" \"npm run server:mock\"",
    "client": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "server": "npm run server:mock",
    "server:mock": "json-server --watch db.json --port 3001"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/vite": "^4.1.4",
    "axios": "^1.8.4",
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "json-server": "^1.0.0-beta.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
